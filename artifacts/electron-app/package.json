{
  "name": "@workspace/electron-app",
  "version": "1.0.0",
  "description": "Probe Commander — Desktop App",
  "author": "Probe Commander",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "node build.mjs",
    "start": "pnpm run build && electron .",
    "dist:linux": "pnpm run build && electron-builder --linux --config electron-builder.config.js",
    "dist:win": "pnpm run build && electron-builder --win --config electron-builder.config.js",
    "dist:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.js"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "0.27.3",
    "typescript": "~5.9.3",
    "@types/node": "^25.3.3"
  }
}
